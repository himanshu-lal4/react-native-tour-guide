#!/bin/sh

# ============================================================
# PRE-COMMIT HOOK — react-native-tour-guide
# ============================================================

# ── 1. Check for merge conflict markers ──
CONFLICT_FILES=$(git diff --cached --name-only -z | xargs -0 grep -rl '^<\{7\}\|^>\{7\}' 2>/dev/null || true)
if [ -n "$CONFLICT_FILES" ]; then
  echo ""
  echo "❌ MERGE CONFLICT MARKERS DETECTED"
  echo ""
  echo "The following staged files contain conflict markers:"
  echo "$CONFLICT_FILES" | while read -r file; do
    echo "  → $file"
  done
  echo ""
  echo "Please resolve conflicts before committing."
  exit 1
fi

# ── 2. Check for accidental secrets/credentials ──
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)
if [ -n "$STAGED_FILES" ]; then
  SECRET_PATTERNS='AKIA[0-9A-Z]{16}|sk-[a-zA-Z0-9]{20,}|ghp_[a-zA-Z0-9]{36}|-----BEGIN (RSA |EC )?PRIVATE KEY-----|password\s*=\s*["\x27][^"\x27]{8,}'
  SECRETS_FOUND=$(echo "$STAGED_FILES" | xargs grep -lE "$SECRET_PATTERNS" 2>/dev/null || true)
  if [ -n "$SECRETS_FOUND" ]; then
    echo ""
    echo "🔐 POTENTIAL SECRETS DETECTED"
    echo ""
    echo "The following files may contain secrets:"
    echo "$SECRETS_FOUND" | while read -r file; do
      echo "  → $file"
    done
    echo ""
    echo "Please review and remove any credentials before committing."
    echo "If this is a false positive, use: git commit --no-verify"
    exit 1
  fi
fi

# ── 3. Check for large files (> 5MB, skip GIFs and tgz) ──
LARGE_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -vE '\.(gif|tgz)$' | while read -r file; do
  if [ -f "$file" ]; then
    SIZE=$(wc -c < "$file" | tr -d ' ')
    if [ "$SIZE" -gt 5242880 ]; then
      echo "  → $file ($(( SIZE / 1024 ))KB)"
    fi
  fi
done)
if [ -n "$LARGE_FILES" ]; then
  echo ""
  echo "📦 LARGE FILES DETECTED (>1MB)"
  echo ""
  echo "$LARGE_FILES"
  echo ""
  echo "Consider using .gitignore or Git LFS for large files."
  exit 1
fi

# ── 4. Lint staged files ──
echo "🔍 Running ESLint on staged files..."
STAGED_JS_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(js|jsx|ts|tsx)$' | grep -v 'node_modules/' | grep -v 'lib/' | grep -v 'example/' || true)
if [ -n "$STAGED_JS_FILES" ]; then
  echo "$STAGED_JS_FILES" | xargs npx eslint --quiet
  if [ $? -ne 0 ]; then
    echo ""
    echo "❌ ESLint errors found. Fix them before committing."
    echo "   Run: yarn lint --fix"
    exit 1
  fi
  echo "✅ ESLint passed"
fi

# ── 5. TypeScript check ──
echo "🔍 Running TypeScript check..."
TSC_OUTPUT=$(npx tsc --noEmit 2>&1)
TSC_ERRORS=$(echo "$TSC_OUTPUT" | grep "^src/" | grep -v "__tests__" | grep "error" | head -5)
if [ -n "$TSC_ERRORS" ]; then
  echo ""
  echo "❌ TypeScript errors found:"
  echo "$TSC_ERRORS"
  echo ""
  echo "   Run: yarn typecheck"
  exit 1
fi
echo "✅ TypeScript passed"

echo ""
echo "✅ All pre-commit checks passed!"
